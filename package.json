{
  "name": "keyguard-express",
  "version": "0.4.2",
  "description": "API key authentication, rate limiting, and abuse prevention as a drop-in Express.js library.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tyrmoga/keyguard_express.git"
  },
  "bugs": {
    "url": "https://github.com/tyrmoga/keyguard_express/issues"
  },
  "homepage": "https://github.com/tyrmoga/keyguard_express#readme",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "keyguard": "dist/cli/index.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "express",
    "middleware",
    "api-key",
    "authentication",
    "rate-limiting",
    "security",
    "hmac",
    "cors",
    "helmet",
    "cli",
    "supply-chain",
    "api-security",
    "authentication"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch examples/basic.ts",
    "start": "tsx examples/basic.ts",
    "cli": "tsx src/cli/index.ts",
    "test": "tsx src/__tests__/run.ts",
    "prepublishOnly": "npm run build && npm test",
    "ci": "npm run build && npm test",
    "prepare": "npm run build"
  },
  "peerDependencies": {
    "express": ">=4.0.0",
    "better-sqlite3": "^11.0.0"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "cors": "^2.8.6",
    "dotenv": "^16.4.0",
    "helmet": "^8.3.0",
    "ioredis": "^5.4.0",
    "pg": "^8.22.0",
    "uuid": "^11.1.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/helmet": "^0.0.48",
    "@types/pg": "^8.20.0",
    "@types/uuid": "^11.0.0",
    "express": "^4.21.0",
    "tsx": "^4.7.0",
    "typescript": "^5.5.0"
  },
  "packageManager": "npm@11.16.0",
  "publishConfig": {
    "access": "public"
  },
  "funding": [
    {
      "type": "github",
      "url": "https://github.com/sponsors/tyrmoga"
    }
  ],
  "overrides": {
    "tar-stream": "3.2.0"
  }
}
