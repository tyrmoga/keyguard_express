# KG_SECRET_KEY — pepper for API key hashing. Auto-generated if not set.
# KG_SECRET_KEY=your-hash-pepper

# KG_ADMIN_KEY — protects /admin/* endpoints (X-Admin-Key header).
# Separate from KG_SECRET_KEY so compromising one doesn't break the other.
# Auto-generated if not set.
# KG_ADMIN_KEY=your-admin-secret

# Database — defaults to SQLite file (keyguard.db)
# DATABASE_URL=sqlite://keyguard.db

# Redis — optional. When set, uses Redis for distributed rate limiting.
# REDIS_URL=redis://localhost:6379/0

# Optional settings
# DEFAULT_RATE_LIMIT_PER_MINUTE=60
# IP_BLOCK_THRESHOLD=100
