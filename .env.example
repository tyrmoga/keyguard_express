# If SECRET_KEY is not set, KeyGuard auto-generates one and
# writes it to .env on first run (it will be loaded automatically
# on subsequent starts). You can also set your own here:
# SECRET_KEY=your-own-secret

# Database — defaults to SQLite file (keyguard.db)
# For PostgreSQL: DATABASE_URL=postgresql://user:pass@localhost:5432/keyguard
# DATABASE_URL=sqlite://keyguard.db

# Redis — optional. When set, uses Redis for distributed rate limiting.
# REDIS_URL=redis://localhost:6379/0

# Optional settings
# DEFAULT_RATE_LIMIT_PER_MINUTE=60
# IP_BLOCK_THRESHOLD=100
